hide_cursor()
clear()
let x = 1

while (x < 25) {
    # Draw the moving object
    cursor(x, 5)
    color(32)
    render "=>"
    
    # Clean up the trail behind it
    cursor(x - 1, 5)
    render " "
    
    # Frame delay in milliseconds (~25 FPS)
    delay(40)
    x += 1
}

# Reset terminal properties to normal
cursor(1, 8)
color(0)
show_cursor()
print "Animation Engine Online!"
