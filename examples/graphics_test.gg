hide_cursor()
clear()
let x = 1

while (x < 25) {
    # Draw the object
    cursor(x, 5)
    color(32)
    render "=>"
    
    # Erase the trail behind it
    cursor(x - 1, 5)
    render " "
    
    # Wait for 40 milliseconds (approx 25 frames per second)
    delay(40)
    x += 1
}

# Reset screen state
cursor(1, 8)
color(0)
show_cursor()
print "Animation Engine Online!"
